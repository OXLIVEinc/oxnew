{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
     "jsx": "react-jsx",

    "lib": ["ES2020"],

    "rootDir": ".",
    "outDir": "./dist",

    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "shared/**/*.ts"
, "src/modules/whatsapp/emails/supportRequestEmail.tsx", "src/modules/whatsapp/services/supportEmail.ts"  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}