{
  "name": "ox-whatsapp-bot",
  "version": "2.0.0",
  "description": "OX Entertainment WhatsApp bot engine (TypeScript) — deep-link ticketing (checkout-link based), hotel booking with room types, recipient-confirmed ticket transfers, pause/resume, Redis sessions, Postgres via Drizzle.",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "worker": "tsx watch src/modules/whatsapp/workers/index.ts",
    "worker:prod": "node dist/src/modules/whatsapp/workers/index.js",
    "simulate": "tsx src/modules/whatsapp/test/simulate.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/modules/whatsapp/db/seed.ts",
    "client": "cd client && bun dev"
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.1.0",
    "@supabase/supabase-js": "^2.110.1",
    "@types/react": "^19.2.17",
    "axios": "^1.18.1",
    "bullmq": "^5.34.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^4.19.2",
    "express-list-routes": "^1.3.2",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.8",
    "openai": "^6.46.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "resend": "^6.17.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.28.1",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  }
}
